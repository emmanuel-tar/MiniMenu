generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



model User {
  id        String             @id @default(uuid())
  email     String             @unique
  password  String
  name      String
  role      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  stationId String?
  station   ProductionStation? @relation(fields: [stationId], references: [id])
  auditLogs AuditLog[]
  settingAudits SettingAudit[]
  orders    Order[]            @relation("OrderWaiter")
}

model Company {
  id           String   @id @default(uuid())
  name         String
  logo         String?
  currency     String   @default("NGN")
  secondaryCurrency String?
  exchangeRate      Float?   @default(1.0)
  taxRate      Float    @default(0)
  enableServiceCharge Boolean  @default(false)
  serviceChargeRate Float?   @default(0)
  contactEmail String?
  phone        String?
  address      String?
  bankName     String?
  accountName  String?
  accountNumber String?
  updatedAt    DateTime @updatedAt
  receiptSettings ReceiptSetting?
  printers       Printer[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  image       String?
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  products    Product[]
}

model ProductGroup {
  id                  String            @id @default(uuid())
  name                String            @unique
  description         String?
  productionStationId String?
  active              Boolean           @default(true)
  createdAt           DateTime          @default(now())
  products            Product[]
  productionStation   ProductionStation? @relation(fields: [productionStationId], references: [id])
}

model ProductionStation {
  id          String       @id @default(uuid())
  name        String       @unique
  code        String?      @unique
  description String?
  printerName String?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  kots        KOT[]
  orderItems  OrderItem[]
  products    Product[]
  users       User[]
  productGroups ProductGroup[]
  printers    Printer[]
}

model Printer {
  id          String            @id @default(uuid())
  name        String
  type        String            @default("BROWSER") // BROWSER, NETWORK, PDF
  ipAddress   String?
  port        Int?
  stationId   String?
  role        String            @default("CASHIER") // CASHIER, KITCHEN, BAR
  active      Boolean           @default(true)
  companyId   String
  createdAt   DateTime          @default(now())
  company     Company           @relation(fields: [companyId], references: [id])
  station     ProductionStation? @relation(fields: [stationId], references: [id])
}

model ReceiptSetting {
  id         String   @id @default(uuid())
  companyId  String   @unique
  showLogo   Boolean  @default(true)
  footerText String?
  showTax    Boolean  @default(true)
  paperSize  String   @default("80mm")
  autoPrint  Boolean  @default(false)
  company    Company  @relation(fields: [companyId], references: [id])
}

model SystemSetting {
  id          String   @id @default(uuid())
  category    String   // e.g., "payment", "feature_toggle", "operations"
  key         String   @unique
  value       String
  type        String   // "string", "number", "boolean", "json"
  description String?
  editable    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SettingAudit {
  id         String   @id @default(uuid())
  userId     String
  settingKey String
  oldValue   String?
  newValue   String
  changedAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Product {
  id              String            @id @default(uuid())
  name            String            @unique
  description     String?
  price           Float
  image           String?
  available       Boolean           @default(true)
  sku             String?           @unique
  barcode         String?           @unique
  categoryId      String?
  groupId         String?
  stationId       String?
  inventoryItemId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  orderItems      OrderItem[]
  inventoryItem   InventoryItem?    @relation(fields: [inventoryItemId], references: [id])
  station         ProductionStation? @relation(fields: [stationId], references: [id])
  group           ProductGroup?      @relation(fields: [groupId], references: [id])
  category        Category?          @relation(fields: [categoryId], references: [id])
}

model InventoryItem {
  id          String     @id @default(uuid())
  name        String
  description String?
  sku         String?    @unique
  unit        String
  quantity    Float      @default(0)
  minStock    Float      @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  products    Product[]
  logs        StockLog[]
}

model StockLog {
  id              String        @id @default(uuid())
  inventoryItemId String
  change          Float
  previousStock   Float
  newStock        Float
  reason          String?
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  module    String
  details   String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String
  method        String   // CASH, POS, TRANSFER, CARD, ONLINE
  amount        Float
  status        String   @default("PENDING") // PENDING, SUBMITTED, SUCCESS, REJECTED
  customerConfirmed Boolean @default(false)
  reference     String?
  paidAt        DateTime @default(now())
  confirmedAt   DateTime?
  order         Order    @relation(fields: [orderId], references: [id])
}

model Table {
  id        String   @id @default(uuid())
  name      String
  capacity  Int      @default(4)
  status    String   @default("AVAILABLE")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  reservations Reservation[]
}

model Reservation {
  id              String   @id @default(uuid())
  customerName    String
  phone           String
  tableId         String?
  table           Table?   @relation(fields: [tableId], references: [id])
  reservationTime DateTime
  guests          Int
  status          String   @default("CONFIRMED") // PENDING, CONFIRMED, SEATED, CANCELLED, NO_SHOW
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Order {
  id                 String      @id @default(uuid())
  tableId            String?
  tableNumber        String?
  status             String      @default("PENDING")
  totalAmount        Float
  taxAmount          Float       @default(0)
  serviceChargeAmount Float      @default(0)
  discountAmount     Float       @default(0)
  guestCount         Int         @default(1)
  waiterId           String?
  waiter             User?       @relation("OrderWaiter", fields: [waiterId], references: [id])
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Service handling (who serves/cashier delivered) and tips
  serviceAssignments ServiceAssignment[]
  tips               Tip[]

  kots               KOT[]
  items              OrderItem[]
  payments           Payment[]
  table              Table?      @relation(fields: [tableId], references: [id])
}

model ServiceAssignment {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])

  personName      String
  role             String
  assignedAt      DateTime @default(now())
  deliveryAssignTime DateTime

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tip             Tip?
}

model Tip {
  id                  String   @id @default(uuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id])

  serviceAssignmentId String? @unique
  serviceAssignment    ServiceAssignment? @relation(fields: [serviceAssignmentId], references: [id])

  tipAmount           Float
  givenAt             DateTime @default(now())
  givenByName         String?
}


model KOT {
  id        String            @id @default(uuid())
  orderId   String
  stationId String
  status    String            @default("PENDING")
  prepTimeMinutes   Int?
  estimatedReadyTime DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  station   ProductionStation @relation(fields: [stationId], references: [id])
  order     Order             @relation(fields: [orderId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id          String            @id @default(uuid())
  orderId     String
  productId   String
  stationId   String
  kotId       String?
  quantity    Int
  productName String
  price       Float
  status      String            @default("PENDING")
  prepTimeMinutes        Int?
  countdownStartedAt      DateTime?
  estimatedCompletionTime DateTime?
  createdAt   DateTime          @default(now())
  kot         KOT?              @relation(fields: [kotId], references: [id])
  station     ProductionStation @relation(fields: [stationId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  order       Order             @relation(fields: [orderId], references: [id])
}

// DB-backed real-time waiter calls (replaces in-memory activeWaiterCalls)
model WaiterCall {
  id          String   @id @default(uuid())
  tableId     String
  tableName   String
  reason      String
  status      String   @default("ACTIVE") // ACTIVE, DISMISSED, HANDLED, EXPIRED
  createdAt   DateTime @default(now())
  handledAt   DateTime?
  expiresAt   DateTime
}

// DB-backed payment selections (replaces in-memory activePaymentSelections)
model PaymentSelection {
  id          String   @id @default(uuid())
  orderId     String   @unique
  method      String
  tableNumber String
  status      String   @default("ACTIVE") // ACTIVE, CLEARED, SETTLED, EXPIRED
  createdAt   DateTime @default(now())
  clearedAt   DateTime?
  expiresAt   DateTime
}

